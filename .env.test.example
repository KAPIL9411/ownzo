# Test Environment Variables
# Used for automated testing and CI/CD

# Environment
NODE_ENV=test

# Firebase Configuration (Test/Emulator)
NEXT_PUBLIC_FIREBASE_API_KEY=test_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=localhost
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-test-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=demo-test-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000:web:test

# Firebase Admin SDK (Test)
FIREBASE_PROJECT_ID=demo-test-project
FIREBASE_CLIENT_EMAIL=test@demo-test-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTEST_KEY\n-----END PRIVATE KEY-----\n"

# Use Firebase Emulators
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199

# Cloudinary Configuration (Test - use test mode)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=test_cloud
CLOUDINARY_API_KEY=test_key
CLOUDINARY_API_SECRET=test_secret

# CSRF Secret (Test)
CSRF_SECRET=test_csrf_secret_for_automated_tests_only

# API Configuration
API_URL=http://localhost:3000/api
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Rate Limiting (disabled or very lenient in tests)
RATE_LIMIT_ENABLED=false

# Error Tracking (disabled in tests)
SENTRY_ENABLED=false

# Logging
LOG_LEVEL=error
LOG_TO_FILE=false

# Feature Flags (all disabled in tests)
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_PUSH_NOTIFICATIONS=false
ENABLE_ANALYTICS=false

# Test-specific
TEST_TIMEOUT=30000
MOCK_EXTERNAL_SERVICES=true
