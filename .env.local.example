# Development Environment Variables
# Copy this file to .env.local and fill in your values

# Environment
NODE_ENV=development

# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_development_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-dev
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-dev.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-project-dev
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-dev.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Cloudinary Configuration
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name_dev
CLOUDINARY_API_KEY=your_api_key_dev
CLOUDINARY_API_SECRET=your_api_secret_dev

# Email (Resend)
RESEND_API_KEY=re_cA2iVK9f_EpmVbLAQpN4ZiDiAChb9Way6

# CSRF Secret (generate with: openssl rand -base64 32)
CSRF_SECRET=your_development_csrf_secret_min_32_chars

# API Configuration
API_URL=http://localhost:3000/api
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Rate Limiting (development - more lenient)
RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=900000
UPLOAD_RATE_LIMIT_MAX=20
UPLOAD_RATE_LIMIT_WINDOW_MS=3600000

# Error Tracking (optional in dev)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_ENABLED=false

# Logging
LOG_LEVEL=debug
LOG_TO_FILE=false

# Feature Flags
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_PUSH_NOTIFICATIONS=false
ENABLE_ANALYTICS=false
