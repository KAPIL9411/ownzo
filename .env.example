# =============================================================================
# OWNZO ENVIRONMENT VARIABLES - EXAMPLE
# =============================================================================
# Copy this file to .env.local for development
# Add these to Vercel Environment Variables for production

# =============================================================================
# FIREBASE CONFIGURATION
# =============================================================================
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Firebase Admin SDK (Server-side)
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# =============================================================================
# CSRF PROTECTION
# =============================================================================
CSRF_SECRET=generate_random_64_char_string_here

# =============================================================================
# APPLICATION URLS
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# =============================================================================
# TRUST ENGINE CONFIGURATION - PHASE 1 (ALL FREE)
# =============================================================================

# Trust Engine Enable/Disable
TRUST_ENGINE_ENABLED=true

# Photo Requirements
TRUST_ENGINE_MIN_PHOTOS_GENERAL=3
TRUST_ENGINE_MIN_PHOTOS_HIGH_VALUE=5
TRUST_ENGINE_HIGH_VALUE_THRESHOLD=10000

# Publishing Decision Thresholds (0-100 scale)
TRUST_ENGINE_AUTO_PUBLISH_THRESHOLD=80
TRUST_ENGINE_SUGGEST_IMPROVEMENTS_THRESHOLD=60
TRUST_ENGINE_REQUIRE_REVIEW_THRESHOLD=40

# Feature Flags - Phase 1 (Free Features Only)
TRUST_ENGINE_ENABLE_BASIC_VALIDATION=true
TRUST_ENGINE_ENABLE_SELLER_SCORING=true
TRUST_ENGINE_ENABLE_LISTING_SCORING=true
TRUST_ENGINE_ENABLE_PRICE_VALIDATION=true
TRUST_ENGINE_ENABLE_CATEGORY_VERIFICATION=true

# Feature Flags - Phase 2+ (Require External APIs - DISABLED for free tier)
TRUST_ENGINE_ENABLE_AI_PHOTO_ANALYSIS=false
TRUST_ENGINE_ENABLE_REVERSE_IMAGE_SEARCH=false
TRUST_ENGINE_ENABLE_AI_CONTENT_ANALYSIS=false
TRUST_ENGINE_ENABLE_MARKET_PRICE_COMPARISON=false

# =============================================================================
# EXTERNAL API KEYS - FREE ALTERNATIVES (Recommended)
# =============================================================================

# GROQ - OpenAI Alternative (FREE & 10x Faster!)
# Get free key: https://console.groq.com
# Free tier: 14,400 requests/day (₹0/month vs OpenAI ₹5,000/month)
GROQ_API_KEY=

# Hugging Face - Google Cloud Vision Alternative (FREE)
# Get free key: https://huggingface.co
# Free tier: 30,000 requests/month (₹0/month vs Google ₹3,000/month)
HUGGINGFACE_API_KEY=

# SerpAPI - Reverse Image Search (FREE Tier)
# Get free key: https://serpapi.com
# Free tier: 100 searches/month (₹0/month vs paid ₹3,000/month)
SERPAPI_API_KEY=

# =============================================================================
# OLD PAID APIS (NOT RECOMMENDED - Only if you really need them)
# =============================================================================

# OpenAI API - For AI content analysis (OPTIONAL - Paid service)
# Leave empty to use GROQ instead (FREE & faster)
OPENAI_API_KEY=

# Google Cloud Vision API - For image analysis (OPTIONAL - Paid after free tier)
# Free tier: 1,000 requests/month
# Leave empty to use Hugging Face instead (FREE & 30K/month)
GOOGLE_CLOUD_VISION_KEY=

# Reverse Image Search API (OPTIONAL - Paid service)
# Leave empty to use SerpAPI free tier instead (100/month free)
REVERSE_IMAGE_SEARCH_API_KEY=

# =============================================================================
# NOTIFICATION SERVICES (All Free Options)
# =============================================================================

# Firebase Cloud Messaging (FREE)
NEXT_PUBLIC_FCM_VAPID_KEY=your_vapid_key

# Email Service - Choose one (All have free tiers):
# Option 1: Resend (Free: 100 emails/day)
RESEND_API_KEY=

# Option 2: SendGrid (Free: 100 emails/day)
SENDGRID_API_KEY=

# Option 3: Mailgun (Free: 5,000 emails/month for 3 months)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# =============================================================================
# ANALYTICS (All Free Options)
# =============================================================================

# Google Analytics (FREE)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Vercel Analytics (FREE on Vercel)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# =============================================================================
# ERROR TRACKING (Free Tiers Available)
# =============================================================================

# Sentry (Free: 5,000 events/month)
NEXT_PUBLIC_SENTRY_DSN=

# =============================================================================
# STORAGE & CDN (All Free Options)
# =============================================================================

# Firebase Storage (FREE tier: 5GB storage, 1GB/day download)
# Already configured via Firebase config above

# Cloudinary (FREE tier: 25 credits/month, 25GB storage)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# =============================================================================
# DATABASE (Already using Firebase Firestore - FREE)
# =============================================================================
# Free tier: 1GB storage, 50K reads/day, 20K writes/day

# =============================================================================
# RATE LIMITING (Free - Built into Next.js)
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_MS=60000

# =============================================================================
# DEVELOPMENT/PRODUCTION FLAGS
# =============================================================================
NODE_ENV=development
NEXT_PUBLIC_ENVIRONMENT=development

# =============================================================================
# NOTES FOR FREE TIER SETUP
# =============================================================================
#
# ✅ INCLUDED FREE (No external APIs needed):
# - Basic Trust Engine (seller + listing scoring)
# - Photo count validation
# - Title/description length checks
# - Price reasonability checks
# - Category-specific requirements
# - Firebase Authentication (50K MAU free)
# - Firebase Firestore (50K reads/day free)
# - Firebase Storage (5GB + 1GB/day free)
# - Vercel Hosting (100GB bandwidth/month free)
#
# 🔄 FREE TIER LIMITS (Optional services):
# - Google Cloud Vision: 1,000 API calls/month free
# - Resend Email: 100 emails/day free
# - SendGrid Email: 100 emails/day free
# - Sentry Errors: 5,000 events/month free
# - Cloudinary Images: 25GB storage free
#
# 💰 PAID ONLY (Not needed for Phase 1):
# - OpenAI API (No free tier - skip AI features)
# - Reverse Image Search APIs (Paid - skip duplicate detection)
# - Advanced AI features (Can add later when revenue comes in)
#
# 🎯 RECOMMENDATION FOR LAUNCH:
# Use only built-in features (no external APIs) for Phase 1.
# The trust engine will work perfectly with:
# - Basic validation (free)
# - Seller scoring (free) 
# - Listing scoring (free)
# - Manual review queue (free)
#
# Add paid features in Phase 2+ when you have revenue.
#
# =============================================================================
