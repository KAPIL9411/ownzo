# Production Environment Variables
# DO NOT commit this file with real values
# Use environment variables in your hosting platform instead

# Environment
NODE_ENV=production

# Firebase Configuration (Production)
NEXT_PUBLIC_FIREBASE_API_KEY=your_production_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-prod
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-prod.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=987654321
NEXT_PUBLIC_FIREBASE_APP_ID=1:987654321:web:fedcba987654

# Firebase Admin SDK (use Secret Manager in production)
FIREBASE_PROJECT_ID=your-project-prod
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-prod.iam.gserviceaccount.com
# DO NOT hardcode private key - use Secret Manager or environment variables
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Cloudinary Configuration (Production)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name_prod
CLOUDINARY_API_KEY=your_api_key_prod
CLOUDINARY_API_SECRET=your_api_secret_prod

# CSRF Secret (generate with: openssl rand -base64 32)
# Store in Secret Manager in production
CSRF_SECRET=your_production_csrf_secret_min_32_chars_different_from_dev

# API Configuration
API_URL=https://your-domain.com/api
NEXT_PUBLIC_API_URL=https://your-domain.com/api

# Rate Limiting (production - strict)
RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_MS=900000
UPLOAD_RATE_LIMIT_MAX=10
UPLOAD_RATE_LIMIT_WINDOW_MS=3600000

# Redis for distributed rate limiting (recommended)
REDIS_URL=redis://your-redis-instance:6379
REDIS_ENABLED=false

# Error Tracking (Sentry)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_ENABLED=true
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Logging
LOG_LEVEL=info
LOG_TO_FILE=true
LOG_FILE_PATH=/var/log/ownzo/app.log

# Feature Flags
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_ANALYTICS=true

# Monitoring
HEALTH_CHECK_ENABLED=true
METRICS_ENABLED=true

# CORS
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Security
SESSION_SECRET=your_production_session_secret_min_32_chars
COOKIE_SECURE=true
COOKIE_SAMESITE=strict
